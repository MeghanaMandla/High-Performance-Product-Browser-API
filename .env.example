# Database connection string for Postgres.
# Examples:
#   - Neon (recommended for free tier):     postgresql://user:password@host/dbname?sslmode=require
#   - Supabase:                             postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#   - Local Postgres (if running locally):  postgresql://user:password@localhost:5432/products
DATABASE_URL=postgresql://user:password@host/dbname

# (Optional) PG connection pool size. Defaults to 10.
PG_POOL_MAX=10

# (Optional) Set to 'false' to disable SSL (only for local development).
# Neon and Supabase both require SSL; leave unset or true in production.
PGSSL=true

# (Optional) Server port. Defaults to 3000.
PORT=3000
